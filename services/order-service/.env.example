# Copy to .env for local dev. Never commit a real .env.
PORT=3000

# IMPORTANT: must match user-service's JWT_SECRET so tokens are valid here.
JWT_SECRET=dev-secret-change-me-in-prod

# Where to call product-service. Defaults match local dev with product-service on host port 3002.
PRODUCT_SERVICE_URL=http://localhost:3002
PRODUCT_TIMEOUT_MS=3000

LOG_LEVEL=info
