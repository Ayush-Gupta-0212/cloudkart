# Copy this file to `.env` and fill in real values for local dev.
# Never commit a real .env — it's in .gitignore.

PORT=3000

# Sign JWTs with this. In production, set to a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=dev-secret-change-me-in-prod

# How long JWTs stay valid. Accepts ms-style: '1h', '15m', '7d'.
JWT_TTL=1h

# pino log level: trace | debug | info | warn | error
LOG_LEVEL=info
