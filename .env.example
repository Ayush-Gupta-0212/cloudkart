# Copy to `.env` to override defaults used by docker-compose.
# .env is gitignored — never commit real secrets.

# Shared JWT secret. user-service signs, order-service verifies.
# Generate a real one with: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=dev-shared-secret-rotate-in-prod-please

# pino log level for all services
LOG_LEVEL=info
